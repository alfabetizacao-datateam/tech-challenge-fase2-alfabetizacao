.terraform.lock.hcl

# Arquivos de plan
*.tfplan
tfplan

# Variáveis com secrets (NUNCA commitar)
terraform.tfvars
*.auto.tfvars
secrets.tfvars

# Logs de crash
crash.log
crash.*.log

